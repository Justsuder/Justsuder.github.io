---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Certifikáty | otahal.me">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-bold mb-8 text-white">Získané <span class="text-indigo-500">Certifikáty</span></h1>
    <p class="text-lg text-slate-400 mb-10">Přehled kurzů a IT certifikací, na kterých průběžně pracuji.</p>

    <div class="space-y-4">
      
      <div class="flex items-center gap-6 bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-indigo-500 transition-colors">
        <div class="w-14 h-14 bg-indigo-500/10 text-indigo-400 flex items-center justify-center rounded-lg flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-white">Cisco Introduction to Networks certificate</h3>
          <p class="text-slate-400 text-sm mt-1">Cisco &bull; Červen 2024</p>
        </div>
      </div>

<div class="flex items-center gap-6 bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-indigo-500 transition-colors">
        <div class="w-14 h-14 bg-indigo-500/10 text-indigo-400 flex items-center justify-center rounded-lg flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-white">Cisco IT Essentials certificate</h3>
          <p class="text-slate-400 text-sm mt-1">Cisco &bull; Červen 2022</p>
        </div>
      </div>

      <div class="flex items-center gap-6 bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-indigo-500 transition-colors">
        <div class="w-14 h-14 bg-indigo-500/10 text-indigo-400 flex items-center justify-center rounded-lg flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-white">ECDL certificate</h3>
          <p class="text-slate-400 text-sm mt-1">ECDL &bull; Listopad 2023</p>
        </div>
      </div>

      <div class="flex items-center gap-6 bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-indigo-500 transition-colors">
        <div class="w-14 h-14 bg-indigo-500/10 text-indigo-400 flex items-center justify-center rounded-lg flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-white">EF-SET C2 English certificate</h3>
          <p class="text-slate-400 text-sm mt-1"> EFSET &bull; Listopad 2023</p>
        </div>
      </div>


    </div>
  </div>
</MainLayout>