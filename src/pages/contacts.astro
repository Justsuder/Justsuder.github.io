---
// src/pages/contacts.astro
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact Me | otahal.me">
  <div class="max-w-4xl mx-auto px-4">
    <h1 class="text-4xl md:text-5xl font-bold mb-8 text-white leading-tight text-center md:text-left">
      Moje <span class="text-indigo-500">kontakty</span>!
    </h1>
    <p class="text-lg text-slate-400 mb-12 max-w-2xl text-center md:text-left mx-auto md:mx-0">
     pro email doporučuji využít formulář
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <a href="mailto:vojtaotahal@gmail.com" class="bg-gray-900 border border-gray-800 rounded-2xl p-6 flex items-center gap-4 hover:border-indigo-500 transition-all hover:scale-[1.03] group">
        <div class="p-3 bg-indigo-500/10 rounded-xl text-indigo-400 group-hover:bg-indigo-500 group-hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium text-slate-500">Hlavní Email</p>
          <p class="text-base font-semibold text-white truncate">vojtaotahal@gmail.cz</p>
        </div>
      </a>

      <a href="mailto:ota0039@vsb.cz" class="bg-gray-900 border border-gray-800 rounded-2xl p-6 flex items-center gap-4 hover:border-indigo-500 transition-all hover:scale-[1.03] group">
