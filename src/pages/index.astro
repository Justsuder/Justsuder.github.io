---
// src/pages/index.astro
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="O mně | otahal.me">
  <div class="flex flex-col md:flex-row items-center justify-between gap-12 md:gap-16">
    
    <div class="flex-1 text-center md:text-left">
      <h1 class="text-5xl md:text-7xl font-bold mb-4 tracking-tight">
        Ahoj, já jsem <span class="text-indigo-500 ">Vojtěch Otáhal</span>
      </h1>
      <p class="text-xl md:text-2xl text-slate-400 max-w-2xl mb-8 mx-auto md:mx-0">
        Student 2. semestru IT na VŠB-TUO a nadšenec do technologií. Postupem času zde budu přidávat své školní i osobní projekty.
      </p>
      
      <a href="/projects" class="inline-flex items-center gap-x-2 text-lg font-semibold bg-indigo-600 text-white px-8 py-3.5 rounded-xl hover:bg-indigo-500 transition-all hover:scale-105 shadow-lg shadow-indigo-600/20">
        Zobrazit mé projekty
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <div class="flex-shrink-0 w-64 h-64 md:w-80 md:h-80 relative">
      <div class="absolute -inset-4 bg-indigo-500/20 rounded-full blur-3xl opacity-70"></div>
      
      <img 
        src="../../public/avatar.jpeg" 
        alt="Avatar Otáhal" 
        class="relative w-full h-full object-cover rounded-full border-4 border-gray-800 shadow-2xl bg-gray-900"
      />
    </div>

  </div>

</MainLayout>