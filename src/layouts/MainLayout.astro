---
// src/layouts/MainLayout.astro
import Header from '../components/Header.astro';
import '../styles/global.css';
// Přebíráme název stránky jako "prop" (vlastnost)
const { title = "Moje Portfolio | otahal.me" } = Astro.props;
---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  
  <body class="bg-gray-950 text-slate-200 min-h-screen flex flex-col font-sans">
    
    <Header />

    <main class="flex-grow container mx-auto px-6 py-12 md:py-20">
      <slot />
    </main>

    <footer class="border-t border-gray-800 bg-gray-900/50 py-6 text-center text-sm text-slate-500">
      <div class="container mx-auto px-6">
        &copy; {new Date().getFullYear()} otahal.me. Vytvořeno s &hearts; v Astru.
      </div>
    </footer>

  </body>
</html>